# Project Healyx — environment variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env`.

# ----- OpenRouter -----
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary model for both agents. Swap per-agent below if you want.
OPENROUTER_DEFAULT_MODEL=nousresearch/hermes-3-llama-3.1-70b

# Per-agent overrides (optional)
TRIAGE_MODEL=nousresearch/hermes-3-llama-3.1-70b
REDTEAM_PLANNER_MODEL=nousresearch/hermes-3-llama-3.1-70b
SAGE_MODEL=nousresearch/hermes-3-llama-3.1-405b  # vulnerable chatbot uses larger model

# Hard spend safety. The agents check this before every call.
OPENROUTER_MONTHLY_USD_CAP=20

# ----- Wazuh -----
WAZUH_API_USER=wazuh-admin
WAZUH_API_PASSWORD=CHANGEME_strong_random_password
WAZUH_INDEXER_PASSWORD=CHANGEME_strong_random_password
WAZUH_DASHBOARD_PASSWORD=CHANGEME_strong_random_password

# ----- Keycloak -----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGEME_strong_random_password
KEYCLOAK_REALM=halcyon-care
KEYCLOAK_DB_PASSWORD=CHANGEME_strong_random_password

# ----- Grafana -----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_strong_random_password

# ----- Caddy / domain -----
PUBLIC_DOMAIN=healyx.example.com  # your actual domain
ACME_EMAIL=you@example.com

# ----- Sage chatbot -----
SAGE_DB_PASSWORD=CHANGEME_strong_random_password
SAGE_SESSION_SECRET=CHANGEME_32_char_random

# ----- Agent runtime -----
TRIAGE_WEBHOOK_TOKEN=CHANGEME_long_random_token  # shared secret Wazuh uses to call triage
GROUND_TRUTH_LOG_PATH=/var/log/healyx/redteam-ground-truth.jsonl
INCIDENT_LOG_PATH=/var/log/healyx/triage-incidents.jsonl

# ----- Misc -----
TZ=Asia/Singapore
LOG_LEVEL=INFO
